class Ponto {
int x;
int y;
Ponto constructor (int x, int y) {
this.x = x;
this.y = y;
}
int soma () {
return this.x + this.y;
}
}

function void main() {
    let int [3] l1 = [0 + 1, 1 + 2, 2 + 3];
let int [3] l2;
    l2[0] = 1;
    l2[1] = 10;
    l2[2] = 100;

    let Ponto p1;
    p1 = new Ponto (1 ,2);
    p1 = null;
    const Ponto p2 = new Ponto (10 ,100);
}

