let int n1 = 10;
let int n2 = 5;

console.log("Maior:", n1 > n2);        // true
console.log("Menor:", n1 < n2);        // false
console.log("Igual:", n1 == n2);       // false
console.log("Diferente:", n1 != n2);   // true
console.log("MaiorIgual:", n1 >= n2);  // true
console.log("MenorIgual:", n1 <= n2);  // false